# ── VPS (bot) ──────────────────────────────────────────────
TELEGRAM_TOKEN=your_bot_token_here
ANTHROPIC_API_KEY=your_claude_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Shared secret between VPS API and Termux worker
WORKER_API_KEY=change-this-to-random-string-32chars

# VPS public address (no trailing slash)
VPS_API_URL=http://YOUR_VPS_IP:8080

# ── Termux worker ──────────────────────────────────────────
# Copy the values above to phone's .env too
# WORKER_API_KEY=same-as-above
# VPS_API_URL=same-as-above
# TELEGRAM_TOKEN=same-as-above (worker sends results directly)
